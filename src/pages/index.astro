---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Whole Brand Academy — Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "DM Sans", system-ui, -apple-system, sans-serif;
        background: #f7f6f4;
        color: #1b263e;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .page-wrap {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
      }
      .card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(27,38,62,0.08), 0 1px 4px rgba(27,38,62,0.04);
        max-width: 680px;
        width: 100%;
        padding: 56px 56px 48px;
        position: relative;
        overflow: hidden;
      }
      .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #1b263e 0%, #64a5bf 60%, #284c6f 100%);
      }
      @media (max-width: 600px) {
        .card { padding: 40px 28px 36px; }
        .page-wrap { padding: 32px 16px; }
      }
      .logo-wrap {
        margin-bottom: 40px;
      }
      .logo-wrap img {
        height: 40px;
        display: block;
      }
      .eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #64a5bf;
        margin-bottom: 16px;
      }
      h1 {
        font-size: clamp(28px, 5vw, 38px);
        font-weight: 700;
        line-height: 1.15;
        color: #1b263e;
        margin: 0 0 24px;
      }
      h1 span {
        color: #64a5bf;
      }
      .divider {
        width: 48px;
        height: 3px;
        background: linear-gradient(90deg, #64a5bf, #284c6f);
        border-radius: 2px;
        margin-bottom: 24px;
      }
      .body-text {
        font-size: 16px;
        line-height: 1.75;
        color: #3a4a5c;
        margin-bottom: 20px;
      }
      .body-text strong {
        color: #1b263e;
        font-weight: 600;
      }
      .preview-note {
        background: #f0f6fa;
        border: 3px solid #64a5bf;
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 14px;
        color: #3a4a5c;
        line-height: 1.65;
        margin-bottom: 36px;
      }
      .module-pills {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 36px;
      }
      .pill {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #eef0f1;
        border-radius: 50px;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 500;
        color: #1b263e;
      }
      .pill-dot {
        width: 8px;
        height: 8px;
        background: #64a5bf;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #1b263e;
        color: white;
        text-decoration: none;
        padding: 16px 32px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        transition: background 0.2s, transform 0.15s;
        letter-spacing: 0.01em;
      }
      .cta-btn:hover {
        background: #284c6f;
        transform: translateY(-1px);
      }
      .cta-btn svg {
        transition: transform 0.2s;
      }
      .cta-btn:hover svg {
        transform: translateX(3px);
      }
      .signature {
        margin-top: 44px;
        padding-top: 28px;
        border-top: 1px solid #eef0f1;
        font-size: 14px;
        color: #7a8a9c;
        line-height: 1.6;
      }
      .signature strong {
        color: #1b263e;
        font-weight: 600;
      }
      footer {
        background: #1b263e;
        color: rgba(255,255,255,0.4);
        text-align: center;
        font-size: 12px;
        padding: 18px 24px;
        letter-spacing: 0.03em;
      }
    </style>
  </head>
  <body>
    <div class="page-wrap">
      <div class="card">
        <div class="logo-wrap">
          <img src="/logos/wba-logo-draft.svg" alt="Whole Brand Academy" />
        </div>

        <div class="eyebrow">Selected Preview — For Herrmann International Asia</div>

        <h1>Welcome, <span>Chris and Michael.</span></h1>

        <div class="divider"></div>

        <p class="body-text">
          Thank you for taking the time to meet with us.
        </p>

        <p class="body-text">
          What follows is a <strong>prototype preview prepared specifically for you</strong> — a window into the Whole Brand Academy experience.
        </p>

        <div class="preview-note">
          This is a <strong>prototype mockup for illustrative purposes only</strong>. The full WBA curriculum spans <strong>20 modules</strong> with supporting downloadables and interactive quizzes throughout. We have intentionally selected only two modules here, because they represent the calibre of the thinking, the quality of the structure, and the commercial potential of what a partnership could unlock.
        </div>

        <p class="body-text">
          Both modules are from <strong>Section 2: Brand Building Blocks</strong>
        </p>

        <div class="module-pills">
          <div class="pill">
            <div class="pill-dot"></div>
            Module 9 — Brand on a Page
          </div>
          <div class="pill">
            <div class="pill-dot"></div>
            Module 10 — Brand Symmetry
          </div>
        </div>

        <a href="/dashboard" class="cta-btn">
          View selected modules
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>

        <div class="signature">
          <strong>Joel Butler &amp; Nick Souter</strong><br />
          Whole Brand Academy
        </div>
      </div>
    </div>

    <footer>
      Whole Brand Academy — Internal Preview · Not for distribution
    </footer>
  </body>
</html>
